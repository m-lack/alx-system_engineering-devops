#!/bin/bash

# Read the input from stdin or a file provided as a command-line argument
if [ "$#" -eq 1 ]; then
    input_file="$1"
else
    input_file="/dev/stdin"
fi

# Extract the hosts or IP addresses from the TSV file and count their occurrences
cut -f 1 "$input_file" | grep -v 'host' | sort | uniq -c | sort -nr | head -n 11 | awk '{print $2}'

